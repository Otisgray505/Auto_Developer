{
  "name": "proxy",
  "version": "1.0.0",
  "description": "Local API Reverse Proxy",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "tsx --test src/**/*.test.ts",
    "tunnel": "tsx src/tunnel.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.0",
    "node-pty": "^1.1.0-beta6",
    "ssh2": "^1.17.0",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.15",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "cloudflared": "^0.7.1",
    "execa": "^5.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}